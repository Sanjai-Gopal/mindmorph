# Web client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_GEMINI_API_KEY=optional_public_key_if_needed
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
NEXT_PUBLIC_HUGGINGFACE_API_KEY=optional_if_client_side_emotion_calls

# Server-side AI
GEMINI_API_KEY=your_server_gemini_key
GEMINI_MODEL=gemini-2.0-flash
HUGGINGFACE_API_KEY=your_huggingface_key

# Server runtime
PORT=4000

# Local infra (docker compose)
DATABASE_URL=postgresql://mindmorph:mindmorph@localhost:5432/mindmorph
REDIS_URL=redis://localhost:6379
CHROMA_URL=http://localhost:8000

# Build/deploy
ANALYZE=false
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TOKEN=your_vercel_token
